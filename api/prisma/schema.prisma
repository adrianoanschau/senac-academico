generator client {
  provider = "prisma-client-js"
  output   = "generated"
}

datasource db {
  provider = "postgresql"
}

enum OverrideType {
  BLOCK
  EXTRA_DAY
}

enum ClassStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Professor {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  degree     String?
  department String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  schedules     Schedule[]
  scheduleRules ScheduleRule[]

  @@map("professors")
}

model Room {
  id        String   @id @default(uuid())
  name      String   @unique
  capacity  Int
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedules     Schedule[]
  scheduleRules ScheduleRule[]

  @@map("rooms")
}

model Course {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  curriculums Curriculum[]

  @@map("courses")
}

model Curriculum {
  id        String   @id @default(uuid())
  name      String
  active    Boolean  @default(true)
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course      Course              @relation(fields: [courseId], references: [id])
  subjects    CurriculumSubject[]
  classGroups ClassGroup[]

  @@map("curriculums")
}

model Subject {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  hours     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  curriculums   CurriculumSubject[]
  schedules     Schedule[]
  scheduleRules ScheduleRule[]

  @@map("subjects")
}

model CurriculumSubject {
  curriculumId String
  subjectId    String
  module       Int

  curriculum Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  subject    Subject    @relation(fields: [subjectId], references: [id], onDelete: Restrict)

  @@id([curriculumId, subjectId])
  @@map("curriculum_subjects")
}

model ClassGroup {
  id           String    @id @default(uuid())
  code         String    @unique
  shift        String
  startDate    DateTime
  endDate      DateTime?
  curriculumId String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  curriculum    Curriculum     @relation(fields: [curriculumId], references: [id], onDelete: Restrict)
  schedules     Schedule[]
  scheduleRules ScheduleRule[]

  @@map("class_groups")
}

model Schedule {
  id        String      @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  status    ClassStatus @default(SCHEDULED)
  cancelReason String?

  classGroupId String
  subjectId    String
  professorId  String
  roomId       String
  ruleId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classGroup ClassGroup    @relation(fields: [classGroupId], references: [id], onDelete: Restrict)
  subject    Subject       @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  professor  Professor     @relation(fields: [professorId], references: [id], onDelete: Restrict)
  room       Room          @relation(fields: [roomId], references: [id], onDelete: Restrict)
  rule       ScheduleRule? @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@map("schedules")
}

model ScheduleOverride {
  id        String       @id @default(uuid())
  title     String
  startTime DateTime
  endTime   DateTime
  type      OverrideType @default(BLOCK)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("schedule_overrides")
}

model ScheduleRule {
  id           String @id @default(uuid())
  daysOfWeek   Int[]
  startTimeStr String
  endTimeStr   String
  totalHours   Int

  classGroupId String
  subjectId    String
  professorId  String
  roomId       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classGroup ClassGroup @relation(fields: [classGroupId], references: [id], onDelete: Restrict)
  subject    Subject    @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  professor  Professor  @relation(fields: [professorId], references: [id], onDelete: Restrict)
  room       Room       @relation(fields: [roomId], references: [id], onDelete: Restrict)
  schedules  Schedule[]

  @@map("schedule_rules")
}
