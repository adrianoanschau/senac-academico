generator client {
  provider = "prisma-client-js"
  output   = "generated"
}

datasource db {
  provider = "postgresql"
}

model Professor {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  degree     String?
  department String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("professors")
}

model Room {
  id        String   @id @default(uuid())
  name      String   @unique
  capacity  Int
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rooms")
}

model Course {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  curriculums Curriculum[]

  @@map("courses")
}

model Curriculum {
  id        String   @id @default(uuid())
  name      String
  active    Boolean  @default(true)
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course      Course              @relation(fields: [courseId], references: [id])
  subjects    CurriculumSubject[]
  classGroups ClassGroup[]

  @@map("curriculums")
}

model Subject {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  hours     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  curriculums CurriculumSubject[]

  @@map("subjects")
}

model CurriculumSubject {
  curriculumId String
  subjectId    String
  module       Int

  curriculum Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  subject    Subject    @relation(fields: [subjectId], references: [id], onDelete: Restrict)

  @@id([curriculumId, subjectId])
  @@map("curriculum_subjects")
}

model ClassGroup {
  id           String    @id @default(uuid())
  code         String    @unique
  shift        String
  startDate    DateTime
  endDate      DateTime?
  curriculumId String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  curriculum Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Restrict)

  @@map("class_groups")
}
